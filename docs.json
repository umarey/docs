{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Immutable",
  "colors": {
    "primary": "#0D0D0D",
    "light": "#4A90D9",
    "dark": "#E5E7EB"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart", "authentication"]
          },
          {
            "group": "Concepts",
            "pages": [
              "guides/events",
              "guides/hash-chain",
              "guides/targets",
              "guides/schemas",
              "guides/exports",
              "guides/log-streams",
              "guides/retention"
            ]
          },
          {
            "group": "SDKs",
            "pages": ["sdks/javascript", "sdks/laravel"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          { "group": "Overview", "pages": ["api-reference/introduction"] },
          {
            "group": "Events",
            "pages": [
              "api-reference/ingest-event",
              "api-reference/batch-events",
              "api-reference/list-events",
              "api-reference/get-event"
            ]
          },
          { "group": "Verification", "pages": ["api-reference/verify-chain"] },
          {
            "group": "Exports",
            "pages": [
              "api-reference/create-export",
              "api-reference/get-export",
              "api-reference/download-export"
            ]
          },
          {
            "group": "Other",
            "pages": ["api-reference/alerts", "api-reference/viewer-token"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://getimmutable.dev",
          "icon": "gauge"
        }
      ]
    }
  },
  "logo": { "light": "/logo/light.svg", "dark": "/logo/dark.svg" },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://getimmutable.dev"
    }
  },
  "footer": {
    "socials": { "x": "https://x.com/getimmutable" }
  }
}
